# Server Config
PORT=3001
NODE_ENV=development

# Google Gemini API
# The Brain: Environmental Lifecycle Assessment Engine
GEMINI_API_KEY=your_gemini_api_key_here

# Backboard API 
# The Memory: Persistent state for institutional sustainability goals
BACKBOARD_API_KEY=your_backboard_api_key_here
BACKBOARD_PROJECT_ID=your_backboard_project_id_here

# Auth0 (Machine-to-Machine for Agent Execution)
# The Execution Layer: Secure authentication to draft alternative POs
AUTH0_DOMAIN=your_auth0_domain.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_m2m_client_id_here
AUTH0_CLIENT_SECRET=your_auth0_m2m_client_secret_here
AUTH0_AUDIENCE=your_auth0_api_audience_here

# Snowflake Data Vault
# Immutable logging of all ecological costs and savings
SNOWFLAKE_ACCOUNT=your_account_locator_here
SNOWFLAKE_USERNAME=your_username_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_WAREHOUSE=your_warehouse_here
SNOWFLAKE_DATABASE=GREENGATE_DB
SNOWFLAKE_SCHEMA=PROCUREMENT
SNOWFLAKE_ROLE=your_role_here
